<!DOCTYPE html>
<html>
  <head>
    <title>Casa 49, Merida, Mexico</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbolinks-cache-control" content="no-cache">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body style="background-image: url('assets/medium_pool.jpg');
  background-repeat: no-repeat;
  height: 100vh;">
    <nav class="navbar navbar-expand-sm navbar-light bg-light">
      <span class="navbar-brand mb-0 h1">Casa 49</span>
      <button 
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        class="navbar-toggler"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item">
            <span class="nav-link" onclick="home()">Home</span>
          </li>
          <li class="nav-item">
            <span class="nav-link" onclick="contactUs()">Contact Us</span>
          </li>
        </ul>
      </div>
    </nav>
    <div>
      <%= yield %>
    </div>
    <script>
      function home() {
        document.getElementById("pageName").innerHTML = "Home";
        document.getElementById("pageText").innerHTML = "Featured on HGTV’s House Hunters International 'Where Are They Now?', Casa Quadro is ideally located 2 blocks from the emblematic Paseo de Montejo, and 1 block behind the ever popular 'Restaurant Row' in Santa Ana.<br><br>At over 2300 square feet, this modern, open-concept home has 2 bedrooms, 2 large bathrooms, and a garage large enough to hold an SUV.<br><br>A stunning 20 foot skylight in the front room provides plenty of light and allows you to stargaze at night.<br><br>Brazilian Granite, a huge kitchen island, and high-end appliances create a dream Chef’s kitchen.<br><br> The gorgeous backyard, complete with filtered pool and lush gardens provide your own private Oasis to enjoy the lovely Merida weather.<br><br> 4 outdoor terraces give you ample opportunity to truly have an outdoor living experience in various areas of this home.";
        }
    </script>
    <script>
      function contactUs() {
        document.getElementById("pageName").innerHTML = "Contact Us";
        pageText = document.getElementById("pageText");
        pageText.innerHTML = "";
      }
    </script>
  </body>
</html>
